// Prisma schema for Vibecode Media Backend

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(uuid())
  email       String       @unique
  name        String?
  password    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  mediaItems  MediaItem[]
  playlists   Playlist[]
}

model MediaItem {
  id          String      @id @default(uuid())
  title       String
  description String?
  type        MediaType   @default(UNKNOWN)
  url         String
  duration    Int?        // seconds
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  owner       User        @relation(fields: [ownerId], references: [id])
  ownerId     String
  playlistItems PlaylistItem[]
}

model Playlist {
  id          String         @id @default(uuid())
  name        String
  description String?
  owner       User           @relation(fields: [ownerId], references: [id])
  ownerId     String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  playlistItems PlaylistItem[]
}

model PlaylistItem {
  id          String      @id @default(uuid())
  playlist    Playlist    @relation(fields: [playlistId], references: [id])
  playlistId  String
  mediaItem   MediaItem   @relation(fields: [mediaItemId], references: [id])
  mediaItemId String
  position    Int         @default(0)
  createdAt   DateTime    @default(now())
}

enum MediaType {
  VIDEO
  AUDIO
  IMAGE
  DOCUMENT
  UNKNOWN
}
